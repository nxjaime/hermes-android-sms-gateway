#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_PATH="${HERMES_ANDROID_SMS_CONFIG:-$ROOT_DIR/.env}"

if [ ! -f "$CONFIG_PATH" ]; then
  echo "Config not found: $CONFIG_PATH" >&2
  echo "Run ./install.sh first." >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_PATH"

key_args=()
if [ -n "${PHONE_KEY_PATH:-}" ]; then
  key_args=(-i "$PHONE_KEY_PATH")
fi

if [ "${1:-}" = "--ssh" ]; then
  ssh -o BatchMode=yes -o ConnectTimeout=10 -p "$PHONE_PORT" "${key_args[@]}"             "${PHONE_USER}@${PHONE_IP}"             'echo connected && whoami && command -v termux-sms-send >/dev/null && echo termux-api-ok'
  exit 0
fi

echo "Config: $CONFIG_PATH"
echo "Phone user: $PHONE_USER"
echo "Phone IP: $PHONE_IP"
echo "Phone port: $PHONE_PORT"
echo
if command -v tailscale >/dev/null 2>&1; then
  echo "Local tailscale status:"
  tailscale status --peers=false | sed -n '1,5p'
  echo
fi
echo "TCP check:"
if command -v nc >/dev/null 2>&1; then
  nc -vz "$PHONE_IP" "$PHONE_PORT"
else
  timeout 5 bash -lc "</dev/tcp/$PHONE_IP/$PHONE_PORT" && echo "port open" || {
    echo "port check failed" >&2
    exit 1
  }
fi
